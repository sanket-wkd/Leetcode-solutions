class Solution {
public:
    int findMaxConsecutiveOnes(vector<int>& nums) {
        int count =0 ;
        int maxcount =0 ;
//Old way to use for loop
//nums.size() right size.nums() wrong
        for(int i  = 0 ; i< nums.size();i++)
        {
            if(nums[i] == 1){
                count ++ ;
                maxcount = max(maxcount, count);//remenber that a variable can used as
//a variable to it self
            }
            else{
                count = 0;//assiging vareiable
            }
        }
        return maxcount;//after complete for loop
        }
    };
