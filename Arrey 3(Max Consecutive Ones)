class Solution {
public:
    int findMaxConsecutiveOnes(vector<int>& nums) {
       int Maxcount = 0;
        int count = 0;
//advance for loop where i points towards  the elements of arrey(single block , induvisiable each items) 

        for(int i : nums){
            if (i == 1){
                count ++;
                Maxcount = max(count,Maxcount );//learn a variable can used another name or 1 var multiple function
            }
            else{
                count = 0;
            }    
        }

            return Maxcount;    
    }
};

